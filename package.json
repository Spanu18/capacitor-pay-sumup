{
  "name": "@capacitor-pay/sumup",
  "version": "0.0.1",
  "description": "Capacitor plugin wrapping the SumUp SDK for in-app card and Tap to Pay checkout. SumUp provider for capacitor-pay.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "dist/",
    "ios/Plugin/",
    "CapacitorPaySumup.podspec",
    "android/src/main/",
    "android/build.gradle"
  ],
  "author": "Alessio Spanu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/capacitor-pay/capacitor-pay-sumup.git"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "sumup",
    "payments"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/core": "^8.1.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "typescript": "~5.6.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
